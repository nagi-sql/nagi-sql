{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "🌊 [nagi](https://github.com/nagi-sql/nagi) 🌊 Configuration.",
  "type": "object",
  "properties": {
    "workspace": {
      "anyOf": [
        {
          "$ref": "#/definitions/Workspace"
        },
        {
          "type": "null"
        }
      ]
    },
    "lsp": {
      "anyOf": [
        {
          "$ref": "#/definitions/LspOptions"
        },
        {
          "type": "null"
        }
      ]
    },
    "format": {
      "anyOf": [
        {
          "$ref": "#/definitions/FormatConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "lint": {
      "anyOf": [
        {
          "$ref": "#/definitions/LintConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "check": {
      "anyOf": [
        {
          "$ref": "#/definitions/TypeCheckOptions"
        },
        {
          "type": "null"
        }
      ]
    },
    "sources": {
      "anyOf": [
        {
          "$ref": "#/definitions/Sources"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "x-tombi-toml-version": "v1.1.0",
  "x-tombi-table-keys-order": "schema",
  "definitions": {
    "Workspace": {
      "title": "Workspace Configuration",
      "type": "object",
      "properties": {
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "sources": {
          "anyOf": [
            {
              "$ref": "#/definitions/Sources"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "members"
      ],
      "x-tombi-table-keys-order": "schema"
    },
    "Sources": {
      "title": "Mapping of Data Sources",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z][a-zA-Z0-9_]*$": {
          "$ref": "#/definitions/SourceOrWorkspace"
        }
      },
      "x-tombi-additional-key-label": "source_name"
    },
    "SourceOrWorkspace": {
      "anyOf": [
        {
          "description": "Use an explicit source definition.",
          "allOf": [
            {
              "$ref": "#/definitions/Source"
            }
          ]
        },
        {
          "description": "Inherit source settings from workspace-level configuration.",
          "allOf": [
            {
              "$ref": "#/definitions/InheritWorkspaceSource"
            }
          ]
        }
      ]
    },
    "Source": {
      "title": "Source Dialect",
      "oneOf": [
        {
          "title": "PostgreSQL Source",
          "description": "Configure a PostgreSQL source.",
          "type": "object",
          "properties": {
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclude": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            },
            "walk": {
              "anyOf": [
                {
                  "$ref": "#/definitions/SourceWalkOptions"
                },
                {
                  "type": "null"
                }
              ]
            },
            "default-database": {
              "type": [
                "string",
                "null"
              ]
            },
            "default-schema": {
              "type": [
                "string",
                "null"
              ]
            },
            "format": {
              "anyOf": [
                {
                  "$ref": "#/definitions/FeatureToggle"
                },
                {
                  "type": "null"
                }
              ]
            },
            "lint": {
              "anyOf": [
                {
                  "$ref": "#/definitions/PostgresSourceLintConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "check": {
              "anyOf": [
                {
                  "$ref": "#/definitions/FeatureToggle"
                },
                {
                  "type": "null"
                }
              ]
            },
            "migration": {
              "anyOf": [
                {
                  "$ref": "#/definitions/MigrationOptions"
                },
                {
                  "type": "null"
                }
              ]
            },
            "overrides": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "$ref": "#/definitions/SourceOverride"
              }
            },
            "dialect": {
              "type": "string",
              "const": "PostgreSQL"
            }
          },
          "additionalProperties": false,
          "required": [
            "dialect",
            "include"
          ]
        },
        {
          "title": "Snowflake Source",
          "description": "Configure a Snowflake source.",
          "type": "object",
          "properties": {
            "include": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclude": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              }
            },
            "walk": {
              "anyOf": [
                {
                  "$ref": "#/definitions/SourceWalkOptions"
                },
                {
                  "type": "null"
                }
              ]
            },
            "default-database": {
              "type": [
                "string",
                "null"
              ]
            },
            "default-schema": {
              "type": [
                "string",
                "null"
              ]
            },
            "format": {
              "anyOf": [
                {
                  "$ref": "#/definitions/FeatureToggle"
                },
                {
                  "type": "null"
                }
              ]
            },
            "lint": {
              "anyOf": [
                {
                  "$ref": "#/definitions/SnowflakeSourceLintConfig"
                },
                {
                  "type": "null"
                }
              ]
            },
            "check": {
              "anyOf": [
                {
                  "$ref": "#/definitions/FeatureToggle"
                },
                {
                  "type": "null"
                }
              ]
            },
            "migration": {
              "anyOf": [
                {
                  "$ref": "#/definitions/MigrationOptions"
                },
                {
                  "type": "null"
                }
              ]
            },
            "overrides": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "$ref": "#/definitions/SourceOverride"
              }
            },
            "dialect": {
              "type": "string",
              "const": "Snowflake"
            }
          },
          "additionalProperties": false,
          "required": [
            "dialect",
            "include"
          ]
        }
      ]
    },
    "SourceWalkOptions": {
      "type": "object",
      "properties": {
        "standard-filters": {
          "anyOf": [
            {
              "$ref": "#/definitions/BooleanDefaultTrue"
            },
            {
              "type": "null"
            }
          ],
          "default": true
        }
      },
      "additionalProperties": false
    },
    "BooleanDefaultTrue": {
      "title": "Boolean wrapper with default `true`.",
      "type": "boolean"
    },
    "FeatureToggle": {
      "type": "string",
      "enum": [
        "on",
        "off"
      ]
    },
    "PostgresSourceLintConfig": {
      "anyOf": [
        {
          "$ref": "#/definitions/FeatureToggle"
        },
        {
          "$ref": "#/definitions/PostgresLintOptions"
        }
      ]
    },
    "PostgresLintOptions": {
      "type": "object",
      "properties": {
        "allowed-parameter-styles": {
          "anyOf": [
            {
              "$ref": "#/definitions/ParameterStyleSet"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "ParameterStyleSet": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ParameterStyle"
      },
      "uniqueItems": true
    },
    "ParameterStyle": {
      "type": "string",
      "enum": [
        "$1",
        "$name",
        "?",
        "?1",
        ":name",
        ":1",
        "@name",
        "%(name)s"
      ]
    },
    "MigrationOptions": {
      "title": "Migration Files Configuration",
      "description": "Narrows the set of source files that contribute DDL (CREATE/ALTER/DROP\nTABLE, CREATE VIEW, CREATE FUNCTION, CREATE TYPE, CREATE INDEX, COMMENT)\nto the schema registry. Files that do not match `include`/`exclude` are\nstill parsed and type-checked as queries, but any DDL they contain is\nignored.\n\nWhen `include` is empty, the migration filter is disabled and every file\nmatched by the surrounding `sources.*.include`/`sources.*.exclude`\nbecomes a DDL source, preserving the previous behavior.",
      "type": "object",
      "properties": {
        "include": {
          "title": "A list of migration files to include for DDL collection.",
          "description": "The files are matched using the glob pattern syntax, evaluated\nrelative to the source root.",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "exclude": {
          "title": "A list of migration files to exclude from DDL collection.",
          "description": "The files are matched using the glob pattern syntax, evaluated\nrelative to the source root.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "SourceOverride": {
      "title": "Source File Override",
      "description": "Applies source-local feature toggles to files matched by `include` and not\nmatched by `exclude`.",
      "type": "object",
      "properties": {
        "include": {
          "description": "Glob patterns matched relative to the source root.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exclude": {
          "description": "Glob patterns excluded relative to the source root.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "format": {
          "description": "Override formatter enablement for matching files.",
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "lint": {
          "description": "Override linter enablement for matching files.",
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "check": {
          "description": "Override type checker enablement for matching files.",
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "include"
      ],
      "x-tombi-table-keys-order": "schema"
    },
    "SnowflakeSourceLintConfig": {
      "anyOf": [
        {
          "$ref": "#/definitions/FeatureToggle"
        },
        {
          "$ref": "#/definitions/SnowflakeLintOptions"
        }
      ]
    },
    "SnowflakeLintOptions": {
      "type": "object",
      "properties": {
        "allowed-parameter-styles": {
          "anyOf": [
            {
              "$ref": "#/definitions/ParameterStyleSet"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "InheritWorkspaceSource": {
      "title": "Inherit Workspace Data Source",
      "type": "object",
      "properties": {
        "workspace": {
          "type": "boolean",
          "enum": [
            true
          ]
        }
      },
      "required": [
        "workspace"
      ]
    },
    "LspOptions": {
      "title": "LSP feature toggles",
      "type": "object",
      "properties": {
        "completion": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "diagnostics": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "formatting": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "goto-definition": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "hover": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "inlay-hint": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "references": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "rename": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "semantic-tokens": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "signature-help": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "workspace-diagnostics": {
          "anyOf": [
            {
              "$ref": "#/definitions/FeatureToggle"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "x-tombi-table-keys-order": "ascending"
    },
    "FormatConfig": {
      "anyOf": [
        {
          "$ref": "#/definitions/FeatureToggle"
        },
        {
          "$ref": "#/definitions/FormatOptions"
        }
      ]
    },
    "FormatOptions": {
      "title": "Formatter options",
      "type": "object",
      "properties": {
        "indent-style": {
          "title": "Indentation character style",
          "description": "- `space`: use spaces\n- `tab`: use tabs\n\nThis affects indentation at clause boundaries and multiline lists.\n\n```sql\nSELECT\n    id\nFROM\n    users;\n-- ^ this indentation uses spaces or tabs\n```",
          "anyOf": [
            {
              "$ref": "#/definitions/IndentStyle"
            },
            {
              "type": "null"
            }
          ],
          "default": "space"
        },
        "indent-width": {
          "title": "Indentation width per nesting level",
          "description": "This option is applied when `indent-style = \"space\"`.\n\n```sql\nSELECT\n    id\nFROM\n    users;\n-- ^ width = 4 example\n```",
          "anyOf": [
            {
              "$ref": "#/definitions/IndentWidth"
            },
            {
              "type": "null"
            }
          ],
          "default": 4
        },
        "line-width": {
          "title": "Maximum target line width",
          "description": "Formatter tries to keep lines within this width by moving lists/clauses to multiline when needed.\n\n```sql\n-- narrow line-width\nSELECT\n    id,\n    name\nFROM\n    users;\n\n-- wide line-width\nSELECT id, name FROM users;\n```",
          "anyOf": [
            {
              "$ref": "#/definitions/LineWidth"
            },
            {
              "type": "null"
            }
          ],
          "default": 80
        }
      },
      "additionalProperties": false,
      "x-tombi-table-keys-order": "schema"
    },
    "IndentStyle": {
      "title": "The style of indentation",
      "description": "Whether to use spaces or tabs for indentation.\n\n- `space`: Use spaces for indentation.\n- `tab`: Use tabs for indentation.",
      "oneOf": [
        {
          "description": "Use spaces for indentation.",
          "type": "string",
          "const": "space"
        },
        {
          "description": "Use tabs for indentation.",
          "type": "string",
          "const": "tab"
        }
      ]
    },
    "IndentWidth": {
      "title": "The number of spaces per indentation level",
      "description": "⚠️ **WARNING** ⚠️\\\nThis option is only used when the indentation style is `space`.",
      "type": "integer",
      "format": "uint8",
      "minimum": 0,
      "maximum": 255
    },
    "LineWidth": {
      "description": "Line width option with validation.",
      "type": "integer",
      "format": "uint8",
      "minimum": 0,
      "maximum": 255
    },
    "LintConfig": {
      "anyOf": [
        {
          "$ref": "#/definitions/FeatureToggle"
        },
        {
          "$ref": "#/definitions/LintOptions"
        }
      ]
    },
    "LintOptions": {
      "title": "Linter options",
      "type": "object",
      "additionalProperties": false,
      "x-tombi-table-keys-order": "schema"
    },
    "TypeCheckOptions": {
      "anyOf": [
        {
          "$ref": "#/definitions/FeatureToggle"
        },
        {
          "$ref": "#/definitions/TypeCheckOptionsTable"
        }
      ]
    },
    "TypeCheckOptionsTable": {
      "title": "Type checker options",
      "type": "object",
      "properties": {
        "rules": {
          "anyOf": [
            {
              "$ref": "#/definitions/CheckRules"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "x-tombi-table-keys-order": "schema"
    },
    "CheckRules": {
      "type": "object",
      "properties": {
        "aggregate-function-context-mismatch": {
          "description": "Report aggregate-only functions used outside valid SQL contexts. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "ambiguous-column": {
          "description": "Report ambiguous column references. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "ambiguous-table": {
          "description": "Report ambiguous table references. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "assignment-type-mismatch": {
          "description": "Report assignment expressions whose resolved type cannot flow into the target column. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "comparison-type-mismatch": {
          "description": "Report incompatible types used in scalar comparisons. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "dialect-mapper": {
          "description": "Report dialect-mapper failures emitted from type-check analysis. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "function-call-ambiguous": {
          "description": "Report function calls that are ambiguous across supported overloads. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "function-argument-count-mismatch": {
          "description": "Report function argument count mismatches. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "function-argument-type-mismatch": {
          "description": "Report function argument type mismatches. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "function-not-immutable-in-context": {
          "description": "Report functions that must be IMMUTABLE in the current SQL context. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "group-by-ordinal-refers-to-aggregate-or-window": {
          "description": "Report GROUP BY ordinals that resolve to aggregate or window expressions. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "group-by-select-expression-not-grouped": {
          "description": "Report SELECT expressions that are neither grouped nor aggregated. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "insert-values-count-mismatch": {
          "description": "Report INSERT VALUES count mismatches. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "join-predicate-type-mismatch": {
          "description": "Report incompatible types used in JOIN predicate comparisons. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "set-operation-column-count-mismatch": {
          "description": "Report set operation column count mismatches. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "set-operation-type-mismatch": {
          "description": "Report set operation columns that cannot coerce both sides to a common type. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "strict-function-nullable-argument": {
          "description": "Report STRICT function calls with nullable arguments. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "type-shadows-builtin": {
          "description": "Report user-defined types that share a name with a built-in type. Default is warn.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "warn"
        },
        "unknown-column": {
          "description": "Report unknown column references. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
        },
        "unknown-function": {
          "description": "Report unknown function references. Default is error.",
          "anyOf": [
            {
              "$ref": "#/definitions/RuleLevel"
            },
            {
              "type": "null"
            }
          ],
          "default": "error"
